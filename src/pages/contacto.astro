---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import personalData from '../data/personal.json';
---

<Layout title={`Contacto - ${personalData.name}`} description="Formulario de contacto para cotizaciones y consultas profesionales.">
  <Header />
  
  <main class="container">
    <section class="contact-section">
      <div class="contact-header animate-fade-in">
        <h1 class="section-title"><i class="ph-duotone ph-paper-plane-tilt"></i> Trabajemos Juntos</h1>
        <p class="section-subtitle">¿Tienes una idea en mente, necesitas un servicio freelancer o quieres hacerme una consulta? Escríbeme y me pondré en contacto contigo pronto.</p>
      </div>

      <div class="contact-grid animate-fade-in delay-1">
        {/* Columna de Información Directa */}
        <div class="info-column">
          <div class="info-card">
            <h3>Información de Contacto</h3>
            <p class="info-text">Si lo prefieres, también puedes escribirme directamente a través de mi correo electrónico o redes sociales.</p>
            
            <div class="info-details">
              <a href={`mailto:${personalData.email}`} class="info-item-link">
                <div class="info-icon">
                  <i class="ph-duotone ph-envelope"></i>
                </div>
                <div>
                  <span class="info-label">Correo Electrónico</span>
                  <span class="info-value">{personalData.email}</span>
                </div>
              </a>
              
              <div class="info-item-link">
                <div class="info-icon">
                  <i class="ph-duotone ph-map-pin"></i>
                </div>
                <div>
                  <span class="info-label">Ubicación</span>
                  <span class="info-value">{personalData.location}</span>
                </div>
              </div>
            </div>

            <div class="info-socials-title">Redes Profesionales</div>
            <div class="info-socials">
              {personalData.socials.map((social) => (
                <a href={social.url} target="_blank" rel="noopener noreferrer" class="social-btn" aria-label={social.name}>
                  <i class={social.icon}></i>
                  <span>{social.name}</span>
                </a>
              ))}
            </div>
          </div>
        </div>

        {/* Columna del Formulario */}
        <div class="form-column">
          {/* Tarjeta de Éxito (Oculta por defecto) */}
          <div id="success-card" class="success-card">
            <div class="success-icon-wrapper">
              <i class="ph-duotone ph-check-circle"></i>
            </div>
            <h2>¡Mensaje Enviado con Éxito!</h2>
            <p>Gracias por escribirme. He recibido tu mensaje y me pondré en contacto contigo lo antes posible para hablar sobre tu proyecto.</p>
            <a href="/" class="btn-success-home">
              <i class="ph ph-house"></i>
              <span>Volver al Inicio</span>
            </a>
          </div>

          {/* Formulario de Contacto */}
          <form id="contact-form" class="contact-form">
            {/* Campos ocultos de Web3Forms */}
            <input type="hidden" name="access_key" value={personalData.web3forms_key} />
            <input type="hidden" name="subject" value="Nuevo contacto desde tu portafolio" />
            <input type="hidden" name="from_name" value={personalData.name} />
            <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

            <div class="form-group">
              <label for="name">Nombre Completo</label>
              <div class="input-wrapper">
                <i class="ph ph-user input-icon"></i>
                <input type="text" id="name" name="name" placeholder="Ej. Juan Pérez" required />
              </div>
            </div>

            <div class="form-group">
              <label for="email">Correo Electrónico</label>
              <div class="input-wrapper">
                <i class="ph ph-envelope-simple input-icon"></i>
                <input type="email" id="email" name="email" placeholder="Ej. juan@correo.com" required />
              </div>
            </div>

            <div class="form-group">
              <label for="phone">Teléfono / WhatsApp <span class="optional">(Opcional)</span></label>
              <div class="input-wrapper">
                <i class="ph ph-phone input-icon"></i>
                <input type="tel" id="phone" name="phone" placeholder="Ej. +52 123 456 7890" />
              </div>
            </div>

            <div class="form-group">
              <label for="service">Servicio de Interés</label>
              <div class="input-wrapper">
                <i class="ph ph-tag input-icon"></i>
                <select id="service" name="service">
                  <option value="general">Consulta General / Otro</option>
                  <option value="landing-pages">Sitios Web & Landing Pages</option>
                  <option value="invitaciones-digitales">Invitaciones Digitales Interactivas</option>
                  <option value="sistemas-gestion">Sistemas de Gestión & Dashboards</option>
                  <option value="apis-plantillas">APIs & Plantillas de Desarrollo</option>
                </select>
              </div>
            </div>

            <div class="form-group">
              <label for="message">Mensaje / Detalles del Proyecto</label>
              <div class="textarea-wrapper">
                <textarea id="message" name="message" rows="5" placeholder="Cuéntame sobre tu idea, objetivos o dudas..." required></textarea>
              </div>
            </div>

            <div id="error-message" class="error-message"></div>

            <button type="submit" id="submit-btn" class="btn-submit">
              <span>Enviar Mensaje</span>
              <i class="ph ph-paper-plane"></i>
            </button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script is:inline>
  (() => {
    const initContactForm = () => {
      const form = document.getElementById('contact-form');
      const successCard = document.getElementById('success-card');
      const submitBtn = document.getElementById('submit-btn');
      const errorMessage = document.getElementById('error-message');
      const serviceSelect = document.getElementById('service');

      if (!form) return;

      // 1. Detectar parámetro "servicio" en la URL para preseleccionar
      const urlParams = new URLSearchParams(window.location.search);
      const serviceParam = urlParams.get('servicio');
      if (serviceParam && serviceSelect) {
        // Mapear parámetros a opciones
        const options = Array.from(serviceSelect.options).map(opt => opt.value);
        if (options.includes(serviceParam)) {
          serviceSelect.value = serviceParam;
        }
      }

      // 2. Procesar el envío mediante AJAX a Web3Forms
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        // Limpiar errores
        errorMessage.style.display = 'none';
        errorMessage.textContent = '';
        
        // Cambiar estado del botón a enviando
        const btnSpan = submitBtn.querySelector('span');
        const btnIcon = submitBtn.querySelector('i');
        const originalText = btnSpan.textContent;
        btnSpan.textContent = 'Enviando...';
        submitBtn.disabled = true;
        if (btnIcon) {
          btnIcon.className = 'ph ph-circle-notch spinner';
        }

        const formData = new FormData(form);
        const object = Object.fromEntries(formData);
        const json = JSON.stringify(object);

        try {
          const response = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Accept': 'application/json'
            },
            body: json
          });
          
          const result = await response.json();
          
          if (response.status === 200 && result.success) {
            // Ocultar formulario y mostrar éxito
            form.style.display = 'none';
            successCard.classList.add('active');
          } else {
            throw new Error(result.message || 'Error al enviar el formulario');
          }
        } catch (error) {
          console.error(error);
          errorMessage.textContent = error.message || 'Ocurrió un error al enviar el mensaje. Por favor, inténtalo de nuevo.';
          errorMessage.style.display = 'block';
          
          // Restaurar botón
          btnSpan.textContent = originalText;
          submitBtn.disabled = false;
          if (btnIcon) {
            btnIcon.className = 'ph ph-paper-plane';
          }
        }
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initContactForm);
    } else {
      initContactForm();
    }
  })();
</script>

<style>
  .contact-section {
    padding: var(--spacing-xl) 0;
  }

  .contact-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto var(--spacing-xl) auto;
  }

  .section-subtitle {
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.6;
    margin-top: var(--spacing-sm);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-xl);
    align-items: start;
  }

  @media (min-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr 1.3fr;
      gap: var(--spacing-lg);
    }
  }

  /* Tarjeta de Información Directa */
  .info-card {
    background-color: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg);
    box-shadow: var(--shadow-sm);
  }

  .info-card h3 {
    font-size: 1.4rem;
    margin-bottom: var(--spacing-sm);
    color: var(--text-primary);
  }

  .info-text {
    color: var(--text-secondary);
    font-size: 0.95rem;
    margin-bottom: var(--spacing-lg);
    line-height: 1.5;
  }

  .info-details {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
  }

  .info-item-link {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    padding: var(--spacing-sm);
    border-radius: var(--radius-md);
    border: 1px solid transparent;
    transition: all 0.2s ease;
  }

  a.info-item-link:hover {
    border-color: var(--border-color);
    background-color: rgba(226, 232, 240, 0.2);
    transform: translateX(3px);
  }

  .info-icon {
    background-color: rgba(59, 130, 246, 0.08);
    color: var(--accent-color);
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .info-item-link:hover .info-icon {
    background: var(--accent-gradient);
    color: white;
  }

  .info-label {
    display: block;
    font-size: 0.8rem;
    color: var(--text-tertiary);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .info-value {
    display: block;
    font-size: 0.95rem;
    color: var(--text-primary);
    font-weight: 600;
    word-break: break-all;
  }

  .info-socials-title {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-tertiary);
    margin-bottom: var(--spacing-md);
    border-top: 1px solid var(--border-color);
    padding-top: var(--spacing-lg);
  }

  .info-socials {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .social-btn {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: 0.65rem 1rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-color);
    background-color: var(--bg-color);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: all 0.2s ease;
  }

  .social-btn:hover {
    border-color: var(--accent-color);
    color: var(--accent-color);
    background-color: var(--bg-surface);
    transform: translateY(-2px);
  }

  .social-btn i {
    font-size: 1.2rem;
  }

  /* Formulario de Contacto */
  .contact-form {
    background-color: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .form-group label {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .optional {
    font-weight: 400;
    color: var(--text-tertiary);
    font-size: 0.8rem;
  }

  .input-wrapper, .textarea-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .input-icon {
    position: absolute;
    left: 1rem;
    color: var(--text-tertiary);
    font-size: 1.2rem;
    pointer-events: none;
    transition: color 0.2s ease;
  }

  .input-wrapper input, .input-wrapper select, .textarea-wrapper textarea {
    width: 100%;
    padding: 0.75rem 1rem 0.75rem 2.8rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-color);
    background-color: var(--bg-color);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 0.95rem;
    outline: none;
    transition: all 0.2s ease;
  }

  /* Select doesn't need icon overlap if styled correctly, but keeping it standard */
  .input-wrapper select {
    appearance: none;
    cursor: pointer;
  }

  .textarea-wrapper textarea {
    padding: 0.75rem 1rem; /* Textarea doesn't use left icon */
    resize: vertical;
  }

  .input-wrapper input:focus, .input-wrapper select:focus, .textarea-wrapper textarea:focus {
    border-color: var(--accent-color);
    background-color: var(--bg-surface);
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.12);
  }

  .input-wrapper input:focus + .input-icon {
    color: var(--accent-color);
  }

  .btn-submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-sm);
    background: var(--accent-gradient);
    color: white;
    border: none;
    border-radius: var(--radius-md);
    padding: 0.85rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.25s ease;
    box-shadow: 0 4px 10px rgba(59, 130, 246, 0.2);
  }

  .btn-submit:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 6px 14px rgba(59, 130, 246, 0.3);
  }

  .btn-submit:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .spinner {
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .error-message {
    display: none;
    color: #ef4444; /* Tailwind red-500 */
    background-color: rgba(239, 68, 68, 0.08);
    border: 1px solid rgba(239, 68, 68, 0.2);
    border-radius: var(--radius-md);
    padding: 0.75rem;
    font-size: 0.88rem;
    text-align: center;
  }

  /* Tarjeta de Éxito */
  .success-card {
    display: none;
    background-color: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl) var(--spacing-lg);
    box-shadow: var(--shadow-sm);
    text-align: center;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-md);
    animation: fadeIn 0.4s ease forwards;
  }

  .success-card.active {
    display: flex;
  }

  .success-icon-wrapper {
    color: #10b981; /* Tailwind emerald-500 */
    font-size: 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .success-card h2 {
    font-size: 1.6rem;
    color: var(--text-primary);
  }

  .success-card p {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
    max-width: 450px;
    margin-bottom: var(--spacing-sm);
  }

  .btn-success-home {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    background-color: var(--text-primary);
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-md);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.2s ease;
  }

  .btn-success-home:hover {
    background-color: var(--accent-color);
    box-shadow: 0 4px 10px rgba(59, 130, 246, 0.2);
    transform: translateY(-2px);
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
