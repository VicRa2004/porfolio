---
import personalData from '../data/personal.json';
---

<section class="hero animate-fade-in delay-1">
  <div class="hero-content">
    <div class="badge"><i class="ph-fill ph-rocket-launch"></i> Disponible para trabajar</div>
    <h1 class="title">
      Construyendo software <br />
      <span class="highlight">con propósito.</span>
    </h1>
    <h2 class="role"><i class="ph-fill ph-terminal-window"></i> {personalData.role}</h2>
    <p class="bio">{personalData.bio}</p>
    
    <div class="actions">
      <a href={`mailto:${personalData.email}`} class="btn btn-primary">
        <i class="ph ph-envelope-simple"></i> Contáctame
      </a>
      <div class="socials">
        {personalData.socials.map((social) => (
          <a href={social.url} target="_blank" rel="noopener noreferrer" class="social-link" aria-label={social.name}>
            <i class={social.icon}></i>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 80vh;
    display: flex;
    align-items: center;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.8rem;
    background-color: rgba(59, 130, 246, 0.1);
    color: var(--accent-color);
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: var(--spacing-lg);
    border: 1px solid rgba(59, 130, 246, 0.2);
  }

  .title {
    font-size: 4rem;
    margin-bottom: var(--spacing-md);
    line-height: 1.1;
  }
  
  .highlight {
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .role {
    font-size: 1.4rem;
    color: var(--text-secondary);
    font-family: var(--font-body);
    font-weight: 500;
    margin-bottom: var(--spacing-lg);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .bio {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin-bottom: var(--spacing-xl);
    line-height: 1.8;
  }

  .actions {
    display: flex;
    align-items: center;
    gap: var(--spacing-xl);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.5rem;
    font-size: 0.95rem;
    font-weight: 600;
    border-radius: var(--radius-md);
    transition: all 0.2s ease;
  }

  .btn-primary {
    background: var(--accent-gradient);
    color: white;
    box-shadow: var(--shadow-md);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
    color: white;
  }

  .socials {
    display: flex;
    gap: var(--spacing-md);
  }

  .social-link {
    font-size: 1.5rem;
    color: var(--text-secondary);
    background-color: var(--bg-surface);
    width: 45px;
    height: 45px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid var(--border-color);
    box-shadow: var(--shadow-sm);
  }

  .social-link:hover {
    color: var(--accent-color);
    border-color: var(--accent-color);
    transform: translateY(-2px);
  }
</style>
